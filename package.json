{
  "name": "ganymede",
  "version": "0.1.0",
  "type": "module",
  "dependencies": {
    "@fontsource/press-start-2p": "^5.2.7",
    "@onrails/pattern": "^0.3.2",
    "typegpu": "^0.11.9",
    "vanjs-core": "^1.6.0"
  },
  "devDependencies": {
    "@webgpu/types": "^0.1.71",
    "bun-plugin-tailwind": "^0.1.2",
    "bun-types": "latest",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2"
  },
  "scripts": {
    "web": "bun --hot src/server.ts",
    "build": "bun run scripts/build.ts",
    "test": "bun test",
    "check": "bun run lint && bun run typecheck",
    "lint": "bun x @biomejs/biome check .",
    "lint:fix": "bun x @biomejs/biome check --write . && bun x @biomejs/biome format --write .",
    "typecheck": "bun x tsc --noEmit",
    "large-files": "bun run scripts/large-files.ts"
  }
}
